[
  {
    "path": "/v1/screenshot/capture",
    "methods": ["POST"],
    "handler": {
      "export": "UrlRewriteHandler",
      "module": "$import(@zuplo/runtime)",
      "options": {
        "rewriteTo": "https://pint-api-delta.vercel.app/api/v1/screenshot/capture"
      }
    },
    "policies": {
      "inbound": ["rate-limit-free-tier"],
      "outbound": ["inject-zuplo-secret"]
    }
  },
  {
