{
  "openapi": "3.1.0",
  "info": {
    "version": "1.0.0",
    "title": "Pint Screenshot API",
    "description": "High-performance API for web screenshots, PDF generation, and OG images."
  },
  "paths": {
    "/v1/screenshot/capture": {
      "post": {
        "summary": "Capture Screenshot",
        "x-zuplo-route": {
          "handler": {
            "export": "urlForwardHandler",
            "module": "$import(@zuplo/runtime)",
            "options": {
              "baseUrl": "https://pint-api-delta.vercel.app/api"
            }
          },
          "policies": {
            "inbound": ["rate-limit-free-tier", "inject-zuplo-secret"]
          }
        },
        "responses": {
          "200": { "description": "OK" }
        }
      }
    },
    "/v1/screenshot/pdf": {
      "post": {
        "summary": "Generate PDF",
        "x-zuplo-route": {
          "handler": {
            "export": "urlForwardHandler",
            "module": "$import(@zuplo/runtime)",
            "options": {
              "baseUrl": "https://pint-api-delta.vercel.app/api"
            }
          },
          "policies": {
            "inbound": ["rate-limit-free-tier", "inject-zuplo-secret"]
          }
        },
        "responses": {
          "200": { "description": "OK" }
        }
      }
    },
    "/v1/screenshot/og": {
      "post": {
        "summary": "Generate OG Image",
        "x-zuplo-route": {
          "handler": {
            "export": "urlForwardHandler",
            "module": "$import(@zuplo/runtime)",
            "options": {
              "baseUrl": "https://pint-api-delta.vercel.app/api"
            }
          },
          "policies": {
            "inbound": ["rate-limit-free-tier", "inject-zuplo-secret"]
          }
        },
        "responses": {
          "200": { "description": "OK" }
        }
      }
    },
    "/health": {
      "get": {
        "summary": "API Health",
        "x-zuplo-route": {
          "handler": {
            "export": "urlForwardHandler",
            "module": "$import(@zuplo/runtime)",
            "options": {
              "baseUrl": "https://pint-api-delta.vercel.app/api"
            }
          }
        },
        "responses": {
          "200": { "description": "OK" }
        }
      }
    }
  }
}
