{
  "version": 2,
  "rewrites": [
    { "source": "/v1/(.*)", "destination": "/api/v1/$1" },
    { "source": "/health", "destination": "/api/health" },
    { "source": "/(.*)", "destination": "/public/$1" }
  ],
  "functions": {
    "api/**/*.js": {
      "maxDuration": 30,
      "memory": 1024
    }
  }
}
